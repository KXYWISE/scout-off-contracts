# ScoutChain Contracts — environment variables
# Copy to .env and fill in all values before deploying

# ============================================================================
# REQUIRED: Deployment & Admin Configuration
# ============================================================================

# Stellar secret key (starts with S) used to deploy and invoke all contracts.
# Must have sufficient XLM balance (~10 XLM on testnet to cover build and deploy).
# WARNING: Keep this secret and never commit to version control.
DEPLOYER_SECRET=

# Stellar G-address that will own and initialize all four contracts.
# This account receives administrative privileges (validator registration, fees, pause/unpause).
ADMIN_ADDRESS=

# Native XLM token contract address on the target network.
# NETWORK-SPECIFIC — must match the network you deploy to:
#   Testnet:  CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
#   Mainnet:  CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA
XLM_TOKEN_ADDRESS=

# ============================================================================
# REQUIRED: Network Configuration
# ============================================================================

# Target Stellar network: testnet or mainnet
# Determines which network contracts are deployed to and which RPC endpoints are used.
# Default: testnet
STELLAR_NETWORK=testnet

# Horizon API endpoint for the target network.
# Used by deployment scripts to query account balances and transaction history.
#   Testnet:  https://horizon-testnet.stellar.org
#   Mainnet:  https://horizon.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint for the target network.
# Used to invoke contract functions and deploy contracts.
#   Testnet:  https://soroban-testnet.stellar.org
#   Mainnet:  https://soroban-mainnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
